# --- Core ---
# Unset DATABASE_URL to run with the in-memory dev store.
DATABASE_URL=
DASHBOARD_TOKEN=
ALLOWED_ORIGINS=*

# --- Scriptwriting (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Voiceover (ElevenLabs) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Video render (Shotstack) ---
SHOTSTACK_API_KEY=
SHOTSTACK_ENV=stage

# --- Storage ---
STORAGE_BACKEND=local
STORAGE_BUCKET=
STORAGE_LOCAL_DIR=./_storage

# --- Affiliate / links ---
AMAZON_ASSOCIATE_TAG=
LINK_DOMAIN=swara.link

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL=

# --- Queue / worker ---
QUEUE_BACKEND=inproc
WORKER_SECRET=

# --- Observability ---
LOG_FORMAT=json
LOG_LEVEL=INFO
ALERT_WEBHOOK=
